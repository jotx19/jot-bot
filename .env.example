OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
# Personal bot identity (shown to users — not the underlying LLM vendor)
BOT_NAME=tinyjot
# Optional extra persona, e.g. "The user is Prabjot, a developer. Be casual."
BOT_PERSONA=
# Serper — 2500 free searches total
# Get key at: serper.dev
SERPER_API_KEY=
# Optional — verified emails by company domain (hunter.io)
HUNTER_API_KEY=
MONGODB_URI=
QDRANT_URL=
QDRANT_API_KEY=
APP_URL=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Protect web UI + API (required in production)
AUTH_PASSWORD=
# Random string for signing session cookies (required if AUTH_PASSWORD is set on Render)
AUTH_SECRET=
# Sandbox — max saved scripts in MongoDB (scheduled jobs are never auto-deleted)
SANDBOX_MAX_SCRIPTS=15
SANDBOX_MAX_CODE_BYTES=32768
