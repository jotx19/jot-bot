# Optional server-wide fallback. Prefer per-user BYOK in Settings → BYOK.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
# Optional server-wide identity fallback. Prefer Settings → General (per user).
BOT_NAME=tinyjot
BOT_PERSONA=
# Serper — 2500 free searches total
# Get key at: serper.dev
SERPER_API_KEY=
# Optional — verified emails by company domain (hunter.io)
HUNTER_API_KEY=
MONGODB_URI=
QDRANT_URL=
QDRANT_API_KEY=
# Express API port (default 5050 — macOS AirPlay often owns 5000)
PORT=5050
# Next.js client origin (CORS + OpenRouter referer)
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:3000
# One Discord bot per deploy (Render env). Allowlist + notify channel → web Settings UI
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_INVITE_URL=https://discord.com/oauth2/authorize?client_id=1161606216984821820
# Or set client id only (builds invite with bot scope + basic permissions)
DISCORD_CLIENT_ID=
# Optional legacy fallbacks if Settings not saved yet
DISCORD_ALLOWED_USER_IDS=
DISCORD_NOTIFY_CHANNEL_ID=
DISCORD_NOTIFY_SCHEDULER=true
DISCORD_NOTIFY_ALWAYS=false
DISCORD_AUTH_SILENT=false
# Cookie signing (required in production with auth)
AUTH_SECRET=
# Google Sign-In (Next client + /api/auth/google)
GOOGLE_CLIENT_ID=
# Optional legacy single-password gate (only used when MongoDB is down)
AUTH_PASSWORD=
# Sandbox — max saved scripts in MongoDB (scheduled jobs are never auto-deleted)
SANDBOX_MAX_SCRIPTS=15
SANDBOX_MAX_CODE_BYTES=32768
